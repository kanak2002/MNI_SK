# Copy this to .env and fill in your values
# Never commit .env to git

# Your OpenRouter API key (from openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Your app URL — shown in OpenRouter dashboard (any URL works)
APP_URL=http://localhost:3000

# Claude model to use via OpenRouter:
#   anthropic/claude-sonnet-4-5   ← recommended (fast, smart, cheaper)
#   anthropic/claude-opus-4-5     ← most capable, use for final demo if budget allows
LLM_MODEL=anthropic/claude-sonnet-4-5
